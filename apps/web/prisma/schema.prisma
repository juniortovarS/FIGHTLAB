generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  role            String   @default("Alumno")
  plan            String   @default("Regular")
  status          String   @default("Activo")
  joinDate        DateTime @default(now())
  planActiveDate  DateTime?
  planExpiryDate  DateTime?
  clasesDisponibles Int    @default(0)
  otpCode         String?
  phone           String?
  reservations    String?  @default("[]")

  @@map("users")
}
