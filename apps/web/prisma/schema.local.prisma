generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              Int      @id @default(autoincrement())
  name            String
  email           String   @unique
  role            String   @default("Alumno")
  plan            String   @default("Regular")
  status          String   @default("Activo")
  joinDate        DateTime @default(now())
  planActiveDate  DateTime?
  planExpiryDate  DateTime?
  clasesDisponibles Int    @default(0)
  otpCode         String?

  @@map("users")
}
